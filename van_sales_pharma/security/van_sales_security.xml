<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Guruhlar -->
        <record id="group_van_agent" model="res.groups">
            <field name="name">Savdo Agenti</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_van_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="implied_ids" eval="[(4, ref('van_sales_pharma.group_van_agent'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Yozuv Qoidalari (Record Rules) -->

        <!-- van.trip -->
        <record id="rule_van_trip_agent" model="ir.rule">
            <field name="name">Agent Trips</field>
            <field name="model_id" ref="model_van_trip"/>
            <field name="domain_force">[('agent_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_van_agent'))]"/>
        </record>
        <record id="rule_van_trip_admin" model="ir.rule">
            <field name="name">Admin Trips</field>
            <field name="model_id" ref="model_van_trip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_van_admin'))]"/>
        </record>

        <!-- van.sale.order -->
        <record id="rule_van_sale_order_agent" model="ir.rule">
            <field name="name">Agent Sales</field>
            <field name="model_id" ref="model_van_sale_order"/>
            <field name="domain_force">[('agent_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_van_agent'))]"/>
        </record>
        <record id="rule_van_sale_order_admin" model="ir.rule">
            <field name="name">Admin Sales</field>
            <field name="model_id" ref="model_van_sale_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_van_admin'))]"/>
        </record>

        <!-- van.nasiya -->
        <record id="rule_van_nasiya_agent" model="ir.rule">
            <field name="name">Agent Nasiya</field>
            <field name="model_id" ref="model_van_nasiya"/>
            <field name="domain_force">[('agent_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_van_agent'))]"/>
        </record>
        <record id="rule_van_nasiya_admin" model="ir.rule">
            <field name="name">Admin Nasiya</field>
            <field name="model_id" ref="model_van_nasiya"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_van_admin'))]"/>
        </record>

        <!-- van.payment -->
        <record id="rule_van_payment_agent" model="ir.rule">
            <field name="name">Agent Payments</field>
            <field name="model_id" ref="model_van_payment"/>
            <field name="domain_force">[('agent_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_van_agent'))]"/>
        </record>
        <record id="rule_van_payment_admin" model="ir.rule">
            <field name="name">Admin Payments</field>
            <field name="model_id" ref="model_van_payment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_van_admin'))]"/>
        </record>
        <!-- van.agent.summary -->
        <record id="rule_van_agent_summary_agent" model="ir.rule">
            <field name="name">Agent Summary - Own</field>
            <field name="model_id" ref="model_van_agent_summary"/>
            <field name="domain_force">[('agent_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_van_agent'))]"/>
        </record>
        <record id="rule_van_agent_summary_admin" model="ir.rule">
            <field name="name">Agent Summary - All</field>
            <field name="model_id" ref="model_van_agent_summary"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_van_admin'))]"/>
        </record>
    </data>
</odoo>
