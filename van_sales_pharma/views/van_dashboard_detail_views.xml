<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_van_dashboard_detail_search" model="ir.ui.view">
        <field name="name">van.dashboard.detail.search</field>
        <field name="model">van.dashboard.detail</field>
        <field name="arch" type="xml">
            <search string="Qidiruv">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="partner_name"/>
                <field name="agent_id"/>
                <filter string="Naqt" name="cash" domain="[('payment_method', '=', 'cash')]"/>
                <filter string="Karta" name="card" domain="[('payment_method', '=', 'card')]"/>
                <filter string="Nasiya" name="nasiya" domain="[('payment_method', '=', 'nasiya')]"/>
                <separator/>
                <filter string="Savdo" name="sale" domain="[('transaction_type', '=', 'sale')]"/>
                <filter string="Kirim" name="kirim" domain="[('transaction_type', '=', 'kirim')]"/>
                <filter string="Chiqim" name="chiqim" domain="[('transaction_type', '=', 'chiqim')]"/>
            </search>
        </field>
    </record>

    <record id="view_van_dashboard_detail_list" model="ir.ui.view">
        <field name="name">van.dashboard.detail.list</field>
        <field name="model">van.dashboard.detail</field>
        <field name="arch" type="xml">
            <list string="Moliyaviy Amaliyotlar" create="0" edit="1" delete="1" decoration-success="transaction_type == 'kirim'" decoration-danger="transaction_type == 'chiqim'" decoration-info="transaction_type == 'sale'">
                <field name="date"/>
                <field name="name" column_invisible="1"/>
                <field name="partner_name"/>
                <field name="agent_id" widget="many2one_avatar_user"/>
                <field name="transaction_type" widget="badge" decoration-success="transaction_type == 'kirim'" decoration-danger="transaction_type == 'chiqim'" decoration-info="transaction_type == 'sale'"/>
                <field name="payment_method" column_invisible="1"/>
                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Jami"/>
                <field name="note" optional="show"/>
                <field name="res_id" column_invisible="1"/>
                <field name="res_model" column_invisible="1"/>
                <field name="currency_id" column_invisible="1"/>
                <button name="action_open_record" type="object" icon="fa-external-link" string="Hujjatni Ochish" class="btn-link"/>
            </list>
        </field>
    </record>

    <record id="view_van_dashboard_detail_form" model="ir.ui.view">
        <field name="name">van.dashboard.detail.form</field>
        <field name="model">van.dashboard.detail</field>
        <field name="arch" type="xml">
            <form string="Amaliyot" create="0" edit="1" delete="1">
                <header>
                    <button name="action_open_record" string="Asl Hujjatni Ochish" type="object" class="btn-primary" icon="fa-external-link"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="1"/>
                            <field name="partner_name" readonly="1"/>
                            <field name="agent_id" readonly="1" widget="many2one_avatar_user"/>
                            <field name="transaction_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="payment_method" readonly="1"/>
                            <field name="amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_van_dashboard_detail" model="ir.actions.act_window">
        <field name="name">Moliyaviy Amaliyotlar</field>
        <field name="res_model">van.dashboard.detail</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_van_dashboard_detail_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Hali moliyaviy amaliyotlar yo'q.
            </p>
        </field>
    </record>

    <!-- Margin Detail View for van.pos.order.line -->
    <record id="view_van_pos_margin_list" model="ir.ui.view">
        <field name="name">van.pos.margin.list</field>
        <field name="model">van.pos.order.line</field>
        <field name="arch" type="xml">
            <list string="Foyda Detallari" create="0" edit="0" delete="0">
                <field name="order_id"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="cost_price" sum="Jami" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="price_unit" string="Sotish Narxi" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="subtotal" string="Jami Tushum" sum="Jami" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="margin" sum="Jami" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
</odoo>
