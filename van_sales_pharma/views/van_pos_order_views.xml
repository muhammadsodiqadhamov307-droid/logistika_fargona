<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_van_pos_order_form" model="ir.ui.view">
        <field name="name">van.pos.order.form</field>
        <field name="model">van.pos.order</field>
        <field name="arch" type="xml">
            <form string="Mobil POS Buyurtmasi">
                <header>
                    <button name="action_confirm_order" string="Tasdiqlash" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="agent_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="nasiya_id"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mahsulotlar" name="products">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right" colspan="2" name="order_total">
                                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                            <div class="oe_clear"/>
                        </page>
                        <page string="Eslatmalar" name="notes">
                            <field name="note" placeholder="Qo'shimcha eslatmalar..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_van_pos_order_tree" model="ir.ui.view">
        <field name="name">van.pos.order.tree</field>
        <field name="model">van.pos.order</field>
        <field name="arch" type="xml">
            <list string="Mobil POS Buyurtmalari" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="agent_id"/>
                <field name="date"/>
                <field name="amount_total"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_van_pos_order" model="ir.actions.act_window">
        <field name="name">Sotuv va Kirimlar</field>
        <field name="res_model">van.dashboard.detail</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('transaction_type', 'in', ['sale', 'kirim'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Hali amaliyotlar yo'q!
            </p>
        </field>
    </record>

    <menuitem id="menu_van_pos_order" 
              name="Sotuv va Kirimlar" 
              parent="menu_van_sales_root"  
              action="action_van_pos_order" 
              sequence="35"/>
</odoo>
