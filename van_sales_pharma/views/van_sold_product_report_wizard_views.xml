<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_van_sold_product_report_wizard_form" model="ir.ui.view">
        <field name="name">van.sold.product.report.wizard.form</field>
        <field name="model">van.sold.product.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Sotilgan Tovarlar Hisoboti" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Sotilgan Tovarlar Hisoboti</h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>

                    <div class="d-flex gap-2 mb-3">
                        <button name="action_generate_report" string="Tasdiqlash" type="object" class="btn btn-primary"/>
                        <button name="action_clear_report" string="Tozalash" type="object" class="btn btn-secondary" invisible="not line_ids"/>
                    </div>

                    <field name="line_ids" nolabel="1" readonly="1" invisible="not line_ids" options="{'no_open': True}">
                        <list create="0" edit="0" delete="0" open_form_view="0">
                            <field name="product_id"/>
                            <field name="qty"/>
                            <field name="standard_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="cost_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="margin_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="actual_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="actual_margin_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="discount_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </list>
                    </field>

                    <group invisible="not line_ids" class="mt-3">
                        <group string="Jami">
                            <field name="total_qty" readonly="1"/>
                            <field name="total_standard_amount" readonly="1"/>
                            <field name="total_cost_amount" readonly="1"/>
                        </group>
                        <group string="Yakuniy">
                            <field name="total_margin_amount" readonly="1"/>
                            <field name="total_actual_amount" readonly="1"/>
                            <field name="total_actual_margin_amount" readonly="1"/>
                            <field name="total_discount_amount" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_van_sold_product_report_wizard" model="ir.actions.act_window">
        <field name="name">Sotilgan Tovarlar Hisoboti</field>
        <field name="res_model">van.sold.product.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_van_sold_product_report"
              name="Sotilgan Tovarlar Hisoboti"
              parent="van_sales_pharma.menu_van_sales_root"
              action="action_van_sold_product_report_wizard"
              sequence="35"/>
</odoo>
