<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
       MIJOZLAR (V2) - UNIQUE IDs to avoid technical view fallbacks
    -->

    <!-- LIST VIEW (V2) -->
    <record id="view_van_customer_list_v2" model="ir.ui.view">
        <field name="name">van.customer.list.v2</field>
        <field name="model">res.partner</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list string="Mijozlar">
                <field name="image_128" widget="image" class="o_list_image"/>
                <field name="name" decoration-bf="1"/>
                <field name="phone"/>
                <field name="street" string="Manzil"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW (V2) -->
    <record id="view_van_customer_form_v2" model="ir.ui.view">
        <field name="name">van.customer.form.v2</field>
        <field name="model">res.partner</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Mijoz">
                <header>
                    <button name="action_van_kirim" type="object" string="Kirim (Qarzni Undirish)" class="oe_highlight btn-success" invisible="x_van_balance &lt;= 0"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_van_balance_details" type="object" class="oe_stat_button" icon="fa-money" invisible="x_van_balance == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value" decoration-success="x_van_balance &gt; 0" decoration-danger="x_van_balance &lt; 0">
                                    <field name="x_van_balance" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Balans</span>
                            </div>
                        </button>
                        <button name="action_view_van_pos_lines" type="object" class="oe_stat_button" icon="fa-cubes" invisible="x_van_pos_product_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-primary">
                                    <field name="x_van_pos_product_count"/> ta
                                </span>
                                <span class="o_stat_text">Olingan Mahsulotlar</span>
                            </div>
                        </button>
                        <button name="action_view_van_pos_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="x_van_pos_total_sum == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="x_van_pos_total_sum" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Jami Xarid</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Haqdor" bg_color="bg-success" invisible="x_van_balance &lt;= 0"/>
                    <widget name="web_ribbon" title="Qarzdor" bg_color="bg-danger" invisible="x_van_balance &gt;= 0"/>
                    <field name="currency_id" invisible="1"/>
                    
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'avatar_128'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Apteka / Mijoz Nomi" required="1"/>
                        </h1>
                        <h3>
                            <field name="phone" placeholder="+998 xx xxx xx xx"/>
                        </h3>
                    </div>

                    <field name="x_is_van_customer" invisible="1"/>
                    <field name="customer_rank" invisible="1"/>
                    <field name="is_company" invisible="1"/>

                    <group>
                        <group string="Manzil">
                            <field name="street" placeholder="Ko'cha, Uy raqami"/>
                            <field name="city" placeholder="Shahar / Tuman"/>
                        </group>
                        <group string="Telegram">
                            <field name="telegram_chat_id" placeholder="Masalan: 123456789"/>
                            <field name="van_agent_id" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="hisob_kitob" string="📋 Hisob-kitob">
                            <!-- Date filter bar -->
                            <div class="d-flex align-items-center gap-2 mb-3 p-2" style="background:#f8f9fa; border-radius:6px; border:1px solid #dee2e6;">
                                <span class="text-muted">📅</span>
                                <field name="hk_date_from" nolabel="1" placeholder="Dan tarixi"/>
                                <span class="text-muted">—</span>
                                <field name="hk_date_to" nolabel="1" placeholder="Gacha tarixi"/>
                                <button name="action_apply_hk_filter" type="object" string="Filtrlash" class="btn btn-sm btn-primary ms-2"/>
                                <button name="action_clear_hk_filter" type="object" string="Tozalash" class="btn btn-sm btn-secondary"/>
                            </div>
                            <field name="x_van_hisob_kitob_html" readonly="1" nolabel="1"/>
                        </page>

                        <page name="ostatka_qarzi" string="Ostatka Qarzi" style="background-color: #FFFDE7; border: 1px solid #ccc; border-radius: 4px; padding: 10px;">
                            <field name="x_van_ostatka_ids">
                                <list editable="bottom" string="Ostatka Qarzi">
                                    <control>
                                        <create name="add_line_control" string="+ Qator qo'shish"/>
                                    </control>
                                    <field name="date"/>
                                    <field name="note" placeholder="Masalan: 2024-yil avgust qarzidan"/>
                                    <field name="amount" sum="Summa"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="x_van_ostatka_total" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page name="notes" string="Izohlar">
                            <field name="comment" placeholder="Qo'shimcha ma'lumot kiritish..." nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW (V2) -->
    <record id="view_van_customer_kanban_v2" model="ir.ui.view">
        <field name="name">van.customer.kanban.v2</field>
        <field name="model">res.partner</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="phone"/>
                <field name="image_128"/>
                <field name="street"/>
                <field name="x_van_total_due"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex">
                            <aside class="o_kanban_aside_full me-2">
                                <field name="image_128" widget="image" class="o_kanban_image"/>
                            </aside>
                            <main>
                                <strong><field name="name"/></strong>
                                <div t-if="record.phone.value" class="text-muted small">
                                    <i class="fa fa-phone me-1" title="Telefon"/><field name="phone"/>
                                </div>
                                <div class="text-muted small mt-1">
                                    <strong>Qarz: </strong>
                                    <span t-attf-class="{{record.x_van_total_due.raw_value > 0 ? 'text-danger fw-bold' : 'text-success fw-bold'}}">
                                        <field name="x_van_total_due" widget="monetary"/>
                                    </span>
                                </div>
                                <!-- Removed agent badge per request -->
                                <div t-if="record.street.value" class="text-muted small mt-1">
                                    <i class="fa fa-map-marker me-1" title="Manzil"/><field name="street"/>
                                </div>
                            </main>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW (V2) -->
    <record id="view_van_customer_search_v2" model="ir.ui.view">
        <field name="name">van.customer.search.v2</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Mijoz nomi" filter_domain="['|', '|', ('name', 'ilike', self), ('parent_id', 'ilike', self), ('ref', '=', self)]"/>
                <field name="phone" string="Telefon"/>
                <separator/>
                <filter name="group_by_city" string="Shahar" context="{'group_by': 'city'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION (V2) -->
    <record id="action_van_customers_v2" model="ir.actions.act_window">
        <field name="name">Mijozlar</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="target">current</field>
        <field name="domain">[('x_is_van_customer', '=', True)]</field>
        <field name="context">{
            'default_x_is_van_customer': True,
            'default_customer_rank': 1,
            'default_is_company': False,
            'res_partner_search_mode': 'customer'
        }</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('van_sales_pharma.view_van_customer_kanban_v2')}),
            (0, 0, {'view_mode': 'list',   'view_id': ref('van_sales_pharma.view_van_customer_list_v2')}),
            (0, 0, {'view_mode': 'form',   'view_id': ref('van_sales_pharma.view_van_customer_form_v2')})]"/>
        <field name="search_view_id" ref="view_van_customer_search_v2"/>
    </record>
</odoo>
