<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sale Order Form View (Mobile Optimized) -->
    <record id="view_van_sale_order_form" model="ir.ui.view">
        <field name="name">van.sale.order.form</field>
        <field name="model">van.sale.order</field>
        <field name="arch" type="xml">
            <form string="Agent Sotuvi">
                <header>
                    <button name="action_confirm" string="Tasdiqlash" type="object" class="btn-primary btn-lg w-100 mb-2" invisible="state != 'draft'"/>
                    
                    <button name="action_pay" string="Naqt To'ldirish" type="object" class="btn-success btn-lg w-100 mb-2" invisible="state != 'confirmed' or payment_method != 'cash'"/>
                    <button name="action_pay" string="Karta Orqali To'lash" type="object" class="btn-info btn-lg w-100 mb-2" invisible="state != 'confirmed' or payment_method != 'card'"/>
                    <button name="action_pay" string="Nasiya / Qarzga Tushirish" type="object" class="text-bg-warning btn-lg w-100 mb-2" invisible="state != 'confirmed' or payment_method != 'nasiya'"/>

                    <button name="action_cancel" string="Bekor Qilish" type="object" class="btn-secondary btn-lg w-100" invisible="state not in ['draft', 'confirmed']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <!-- Mobile-first grouping: all fields full width in vertical column -->
                        <field name="partner_id" readonly="state != 'draft'" placeholder="Mijoz (Tanlash ixtiyoriy lekin nasiya uchun shart)"/>
                        <field name="payment_method" readonly="state != 'draft'" widget="radio" options="{'horizontal': true}"/>
                        <field name="trip_id" readonly="state != 'draft'"/>
                        <field name="date" readonly="1"/>
                        <field name="invoice_id" readonly="1" invisible="not invoice_id"/>
                        <field name="nasiya_id" readonly="1" invisible="payment_method != 'nasiya'"/>
                        <field name="company_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Sotuv Satrlari">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>

                                    <field name="price_unit" readonly="1"/>
                                    <field name="subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right" colspan="2">
                                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}" style="font-size: 1.5em; font-weight: bold;"/>
                            </group>
                            <field name="note" placeholder="Qo'shimcha izoh..." class="mt-4"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_van_sale_order_tree" model="ir.ui.view">
        <field name="name">van.sale.order.tree</field>
        <field name="model">van.sale.order</field>
        <field name="arch" type="xml">
            <list string="Sotuvlar" decoration-muted="state == 'draft'" decoration-success="state == 'paid'" decoration-warning="state == 'nasiya'" decoration-info="state == 'confirmed'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="agent_id"/>
                <field name="date"/>
                <field name="payment_method"/>
                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_van_sale_all" model="ir.actions.act_window">
        <field name="name">Barcha Sotuvlar</field>
        <field name="res_model">van.sale.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_van_sale_mine" model="ir.actions.act_window">
        <field name="name">Mening Sotuvlarim</field>
        <field name="res_model">van.sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('agent_id', '=', uid)]</field>
    </record>
</odoo>
