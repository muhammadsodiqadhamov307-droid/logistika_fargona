<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View -->
    <record id="view_van_product_kanban" model="ir.ui.view">
        <field name="name">van.product.kanban</field>
        <field name="model">van.product</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="image_1920"/>
                <field name="qty"/>
                <field name="cost_price"/>
                <field name="list_price"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside class="o_kanban_aside_full d-flex align-items-center justify-content-center">
                            <field name="image_1920" widget="image" options="{'size': [128, 128], 'img_class': 'mw-100 object-fit-contain'}" alt="Product Image"/>
                        </aside>
                        <main class="p-2">
                            <strong class="o_kanban_record_title fs-5 mb-1 d-block">
                                <field name="name"/>
                            </strong>
                            <div class="mt-1">
                                <strong>Soni: <span class="text-primary"><field name="qty"/></span></strong>
                            </div>
                            <div>
                                Sotish: <field name="list_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>
                            <div class="text-muted">
                                Kelish: <field name="cost_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tree/List View -->
    <record id="view_van_product_tree" model="ir.ui.view">
        <field name="name">van.product.tree</field>
        <field name="model">van.product</field>
        <field name="arch" type="xml">
            <list string="Mahsulotlar">
                <field name="name"/>
                <field name="qty"/>
                <field name="list_price" widget="monetary"/>
                <field name="cost_price" widget="monetary" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_van_product_form" model="ir.ui.view">
        <field name="name">van.product.form</field>
        <field name="model">van.product</field>
        <field name="arch" type="xml">
            <form string="Mahsulot">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" string="Mahsulot Nomi"/>
                        <h1>
                            <field name="name" placeholder="Masalan: Aspirin C"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="qty"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="list_price" widget="monetary"/>
                            <field name="cost_price" widget="monetary"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sotuv Hisoboti">
                            <group string="Filtrlar">
                                <group>
                                    <field name="sale_report_date_from"/>
                                    <field name="sale_report_date_to"/>
                                </group>
                                <group>
                                    <field name="sale_report_agent_id"/>
                                    <field name="sale_report_partner_id"/>
                                </group>
                            </group>
                            <div class="mb-2">
                                <button name="action_apply_sale_report_filters" string="Filterlash" type="object" class="btn-primary me-2"/>
                                <button name="action_clear_sale_report_filters" string="Filtrlarni Tozalash" type="object" class="btn-secondary"/>
                            </div>
                            <field name="sale_report_line_ids" nolabel="1">
                                <list string="Mahsulot Sotuvlari" create="0" delete="0" default_order="sale_date desc,id desc">
                                    <field name="sale_date" string="Sana"/>
                                    <field name="sale_agent_id" string="Agent"/>
                                    <field name="sale_partner_id" string="Mijoz"/>
                                    <field name="qty" string="Miqdor"/>
                                    <field name="price_unit" string="Narx" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="subtotal" string="Summa" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Mahsulot Yuklash Hisoboti">
                            <group string="Filtrlar">
                                <group>
                                    <field name="trip_report_date_from"/>
                                    <field name="trip_report_date_to"/>
                                </group>
                                <group>
                                    <field name="trip_report_agent_id"/>
                                    <field name="trip_report_taminotchi_id"/>
                                </group>
                            </group>
                            <div class="mb-2">
                                <button name="action_apply_trip_report_filters" string="Filterlash" type="object" class="btn-primary me-2"/>
                                <button name="action_clear_trip_report_filters" string="Filtrlarni Tozalash" type="object" class="btn-secondary"/>
                            </div>
                            <field name="trip_report_line_ids" nolabel="1">
                                <list string="Mahsulot Yuklashlari" create="0" delete="0" default_order="trip_date desc,id desc">
                                    <field name="trip_date" string="Sana"/>
                                    <field name="trip_taminotchi_id" string="Taminotchi"/>
                                    <field name="trip_agent_id" string="Agent"/>
                                    <field name="loaded_qty" string="Miqdor"/>
                                    <field name="price_unit" string="Kelish Narxi" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="sale_price_unit" string="Sotish Narxi" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_subtotal" string="Summa" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_van_product" model="ir.actions.act_window">
        <field name="name">Mahsulotlar</field>
        <field name="res_model">van.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Birinchi mahsulotingizni qo'shing!
            </p>
        </field>
    </record>
</odoo>
